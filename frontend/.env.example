# --- Atlas (recommended): single host + SRV ---
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# --- Atlas alternative: no SRV (if querySrv times out). Copy full string from Atlas UI; do NOT use only cluster0... with mongodb:// ---
# MONGODB_URI=mongodb://USER:PASSWORD@shard-00-00.xxxxx.mongodb.net:27017,shard-00-01.xxxxx.mongodb.net:27017,shard-00-02.xxxxx.mongodb.net:27017/?authSource=admin&replicaSet=atlas-xxxxx-shard-0&retryWrites=true&w=majority

MONGODB_DB_NAME=openmind
AUTH_SESSION_TTL_DAYS=7
