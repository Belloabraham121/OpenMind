{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/dashboard/layout,_N_T_/dashboard/multimodal/layout,_N_T_/dashboard/multimodal/page,_N_T_/dashboard/multimodal"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/dashboard/multimodal/__PAGE__",
    "/dashboard/multimodal",
    "/dashboard",
    "/_index",
    "/_head"
  ]
}