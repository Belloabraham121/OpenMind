{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/dashboard/layout,_N_T_/dashboard/durability/layout,_N_T_/dashboard/durability/page,_N_T_/dashboard/durability"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/dashboard/durability/__PAGE__",
    "/dashboard/durability",
    "/dashboard",
    "/_index",
    "/_head"
  ]
}